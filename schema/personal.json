        "Archived": {"type": "checkbox"}
      }
    },
    "finance_transactions": {
      "title": "Finance Transactions",
      "properties": {
        "Date": {"type": "date"},
        "Description": {"type": "title"},
        "Kind": {"type": "select", "options": ["Income", "Expense", "Transfer"]},
        "Amount": {"type": "number"},
        "Currency": {"type": "select", "options": ["INR", "USD", "EUR", "GBP"]},
        "Tags": {"type": "multi_select", "options": []},
        "Note": {"type": "rich_text"}
      }
    },
    "budgets": {
      "title": "Budgets",
      "properties": {
        "Description": {"type": "title"},
        "Month Start": {"type": "date"},
        "Amount": {"type": "number"}
      }
    }
  }
}
