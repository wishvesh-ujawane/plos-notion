{
  "areaKey": "personal",
  "pageTitle": "🧘 Personal",
  "pageIcon": "🧘",
  "databases": {
    "tasks": {
      "title": "Tasks",
      "properties": {
        "Title": {"type": "title"},
        "Status": {"type": "select", "options": ["Todo", "Doing", "Done"]},
        "Priority": {"type": "select", "options": ["P1", "P2", "P3", "P4"]},
        "Due": {"type": "date"},
        "Today": {"type": "checkbox"},
        "Notes": {"type": "rich_text"}
      }
    },
    "projects": {
      "title": "Projects",
      "properties": {
        "Title": {"type": "title"},
        "Type": {"type": "select", "options": ["Personal", "Official"]},
        "Status": {"type": "select", "options": ["Active", "Paused", "Archived", "Abandoned"]},
        "Emoji": {"type": "rich_text"},
        "Color": {"type": "select", "options": ["Slate", "Red", "Orange", "Amber", "Yellow", "Green", "Teal", "Blue", "Indigo", "Purple", "Pink"]},
        "Notes": {"type": "rich_text"}
      }
    },
    "habits": {
      "title": "Habits",
      "properties": {
        "Title": {"type": "title"},
        "Ritual": {"type": "select", "options": ["Morning", "Evening", "None"]},
        "Active": {"type": "checkbox"},
        "Notes": {"type": "rich_text"}
      }
    },
    "habit_logs": {
      "title": "Habit Logs",
      "properties": {
        "Date": {"type": "title"},
