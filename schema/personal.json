        "Target Date": {"type": "date"},
        "Progress %": {"type": "number", "format": "percent"},
        "Status": {"type": "select", "options": ["Active", "Achieved", "Archived"]}
      }
    },
    "daily_plan": {
      "title": "Daily Plan",
      "properties": {
        "Date": {"type": "title"},
        "Work Mode": {"type": "select", "options": ["WFH", "WFO", "Saturday", "Sunday"]},
